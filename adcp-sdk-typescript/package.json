{
  "name": "@protocol-commerce/adcp-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Agentic Discovery Commerce Protocol (AdCP)",
  "license": "MIT",
  "author": "Protocol Commerce Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexbid-dev/protocol-commerce"
  },
  "keywords": [
    "adcp",
    "protocol-commerce",
    "agentic-commerce",
    "mcp",
    "ai-agents",
    "product-discovery",
    "open-protocol"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
